{
  "name": "partsbox-clone",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source self-hosted electronic parts inventory, BOM, and build manager",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "npm run dev -w backend",
    "build": "npm run build -w backend && npm run build -w frontend",
    "test": "npm test -w backend",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "db:migrate": "npm run db:migrate -w backend",
    "db:seed": "npm run db:seed -w backend",
    "db:reset": "npm run db:reset -w backend"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4"
  }
}
