{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "extends": ["../../biome.json"],
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": { "noExplicitAny": "error" },
      "security": { "noDangerouslySetInnerHtml": "error" },
      "style": { "useImportType": "off" },
      "correctness": {
        "noUnusedVariables": "warn",
        "useExhaustiveDependencies": "off"
      }
    }
  },
  "files": {
    "include": ["src/**/*.ts"]
  }
}
