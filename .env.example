# --- Server ---
NODE_ENV=development
HOST=127.0.0.1
PORT=3001

# --- Database ---
# Default path is relative to backend/prisma/ (where schema.prisma lives).
# For local dev: leave as-is. For production: postgresql://user:password@host:5432/dbname
DATABASE_URL=file:./dev.db

# --- Security ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET=change-me-to-32-random-bytes-base64

# --- CORS ---
# Comma-separated origins allowed to call the API. Frontend dev default included.
# Use trailing * for wildcard (e.g. https://*.serveousercontent.com matches
# any subdomain), useful for free SSH tunnels whose hostname changes per session.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://*.serveousercontent.com

# --- Rate limit ---
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=5

# --- Logging ---
LOG_LEVEL=info
