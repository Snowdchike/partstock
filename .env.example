# --- Server ---
NODE_ENV=production
HOST=127.0.0.1
PORT=3001

# --- Database ---
# Relative to backend/prisma/ (schema.prisma directory).
# SQLite (default): file:./dev.db
# PostgreSQL: postgresql://user:password@host:5432/partstock
DATABASE_URL=file:./dev.db

# --- Security ---
# Generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# Must be ≥32 chars, base64url-safe.
SESSION_SECRET=change-me-to-32-random-bytes-base64url

# --- CORS ---
# Must include the exact origin users open in the browser.
# LAN example: http://192.168.1.10:3001
ALLOWED_ORIGINS=http://127.0.0.1:3001,http://localhost:3001,http://localhost:5173,http://127.0.0.1:5173

# --- Rate limit ---
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=5

# --- Logging ---
LOG_LEVEL=info
